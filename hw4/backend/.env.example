# 後端環境變數範例
# 複製此檔案為 .env 並填入實際值

# 伺服器設定
PORT=3000

# CORS 設定
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 資料庫設定
DATABASE_URL=file:./dev.db

# JWT 認證設定
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Google Maps API 設定
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key_here
