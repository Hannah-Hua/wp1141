# 伺服器設定
PORT=3000
NODE_ENV=development

# CORS 設定
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 資料庫設定
DATABASE_URL=./dev.db

# JWT 設定
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Google Maps Server Key（已啟用 Geocoding/Places/Directions）
# 限制類型：IP 位址（開發階段暫無限制，部署時需設定）
# ⚠️ 安全風險：開發階段無 IP 限制，請勿將此 Key 用於生產環境
GOOGLE_MAPS_SERVER_KEY=YOUR_SERVER_KEY
